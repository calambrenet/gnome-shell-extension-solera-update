msgid "Check for updates"
msgstr "Buscar actualizaciones"

msgid "Solera is up to date"
msgstr "Solera está al día"

msgid "Checking for updates…"
msgstr "Comprobando actualizaciones…"

msgid "Checking…"
msgstr "Comprobando…"

msgid "Update available"
msgstr "Actualización disponible"

msgid "Update now"
msgstr "Actualizar ahora"

msgid "Deploying update…"
msgstr "Desplegando actualización…"

msgid "Deploying…"
msgstr "Desplegando…"

msgid "Restart to apply the update"
msgstr "Reinicia para aplicar la actualización"

msgid "Restart now"
msgstr "Reiniciar ahora"

msgid "Could not check (no network?)"
msgstr "No se pudo comprobar (¿sin red?)"

msgid "Retry"
msgstr "Reintentar"

msgid "Installed"
msgstr "Instalada"

msgid "Could not start the update:"
msgstr "No se pudo lanzar la actualización:"

msgid "The update did not complete."
msgstr "La actualización no se completó."

msgid "Could not restart:"
msgstr "No se pudo reiniciar:"

msgid "Solera update available"
msgstr "Actualización de Solera disponible"

msgid "A new system image is ready to deploy."
msgstr "Hay una nueva imagen del sistema lista para desplegar."

msgid "Update ready"
msgstr "Actualización lista"

msgid "Restart to boot into the new version of Solera."
msgstr "Reinicia para arrancar con la nueva versión de Solera."
